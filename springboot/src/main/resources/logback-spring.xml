<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty name="RAB_HOST"     scope="context" source="spring.rabbitmq.host"     defaultValue="devcontext.duckdns.org"/>
    <springProperty name="RAB_PORT"     scope="context" source="spring.rabbitmq.port"     defaultValue="5672"/>
    <springProperty name="RAB_USERNAME" scope="context" source="spring.rabbitmq.username" defaultValue="guest"/>
    <springProperty name="RAB_PASSWORD" scope="context" source="spring.rabbitmq.password" defaultValue="guest"/>

    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="AMQP" class="org.springframework.amqp.rabbit.logback.AmqpAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <host>${RAB_HOST}</host>
        <port>${RAB_PORT}</port>
        <username>${RAB_USERNAME}</username>
        <password>${RAB_PASSWORD}</password>

        <declareExchange>true</declareExchange>
        <exchangeName>log-exchange</exchangeName>
        <exchangeType>topic</exchangeType>
        <routingKeyPattern>log.key</routingKeyPattern>
        <generateId>true</generateId>
        <charset>UTF-8</charset>

        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <appender-ref ref="AMQP" />
    </root>

</configuration>