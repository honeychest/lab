# [AGENT] Nginx 설정 — sticky session(SRV_ID 쿠키), SSE app1 고정 라우팅, rate limit
# 연관: docker-compose.yaml (app1=8080 polling, app2=8081 disabled)

# 1. 백엔드 서버 그룹 정의 (상황별로 3가지 그룹을 만듭니다)

# 쿠키가 없을 때 사용하는 기본 그룹
upstream chs-nginx-server {
    server 127.0.0.1:8080 max_fails=2 fail_timeout=3s;
    server 127.0.0.1:8081 max_fails=2 fail_timeout=3s;
}

# DOCKER1 쿠키용: 8080을 우선하되, 죽으면 8081이 즉시 대리 응답(backup)
upstream backend_docker1 {
    server 127.0.0.1:8080 max_fails=1 fail_timeout=3s;
    server 127.0.0.1:8081 backup;
}

# DOCKER2 쿠키용: 8081을 우선하되, 죽으면 8080이 즉시 대리 응답(backup)
upstream backend_docker2 {
    server 127.0.0.1:8081 max_fails=1 fail_timeout=3s;
    server 127.0.0.1:8080 backup;
}

# 2. [추가] 응답 준 서버 주소를 이름으로 변환하는 매핑 로직
# $upstream_addr가 "127.0.0.1:8081"이면 "docker2"라는 글자를 생성합니다.
map $upstream_addr $inferred_name {
    "~127.0.0.1:8080" "docker1";
    "~127.0.0.1:8081" "docker2";
    default           "unknown";
}

# 2. 쿠키 값에 따른 백엔드 매핑 (IP 주소가 아닌 위에서 만든 '그룹명'을 지정합니다)
map $cookie_SRV_ID $sticky_backend {
    "docker1"    backend_docker1;
    "docker2"    backend_docker2;
    "local"      backend_docker1;
    default      chs-nginx-server;
}

# Telegram 전송용 Rate Limiting
limit_req_zone $binary_remote_addr zone=support_inquiry:10m rate=5r/m;

server {
    listen 80;
    server_name 43.202.170.251;

    root /home/ubuntu/project/home/frontend/dist;
    index index.html;

    # 5xx 발생 시 디자인된 정적 페이지로 응답 (FE 빌드/백엔드 다운 시 기본 Nginx 페이지 대신)
    error_page 500 502 503 504 /50x.html;

    location / {
        try_files $uri /index.html;
    }

    # ── SSE 전용 블록 ────────────────────────────────────────────────────────
    # [컨벤션] SSE 엔드포인트는 반드시 /sse 로 끝나야 한다.
    #   예) /api/binance/trades/sse, /api/support/notify/sse
    #   이유: proxy_buffering off + proxy_read_timeout 3600s 가 필요한데
    #         /api 블록(timeout 10s, buffering on)으로 들어가면 연결이 끊긴다.
    #   신규 SSE 추가 시 URL을 /sse 로 끝내면 이 블록에 자동 적용되므로 별도 설정 불필요.
    location ~ ^/api/.+/sse$ {
        proxy_pass http://$sticky_backend;

        proxy_http_version 1.1;
        proxy_set_header Connection '';          # SSE는 keep-alive (upgrade 아님)
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        proxy_buffering off;                     # 버퍼링 시 이벤트 전달 안 됨
        proxy_cache off;
        proxy_read_timeout 3600s;

        proxy_intercept_errors off;
    }

    # 문의 전송만 rate limit 적용
    location /api/support/inquiry {
        limit_req zone=support_inquiry burst=2 nodelay;
        limit_req_status 429;

        proxy_pass http://$sticky_backend;

        proxy_next_upstream error timeout invalid_header http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
        proxy_connect_timeout 2s;
        proxy_read_timeout 10s;

        add_header Set-Cookie "SRV_ID=$inferred_name; Path=/; HttpOnly" always;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_intercept_errors off;
    }

    # API 요청 처리
    location /api {
        proxy_pass http://$sticky_backend;

        # 장애 발생 시 즉시 다음 서버로 넘기는 설정
        proxy_next_upstream error timeout invalid_header http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
        proxy_connect_timeout 2s;
        proxy_read_timeout 10s;

        # [핵심] 성공한 서버의 이름으로 쿠키를 강제 갱신 (DOCKER1 -> DOCKER2 자동 교체)
        add_header Set-Cookie "SRV_ID=$inferred_name; Path=/; HttpOnly" always;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # 5xx 시 server 블록의 error_page(50x.html)로 응답
        proxy_intercept_errors on;
    }

    # WebSocket 요청 처리
    location /ws {
        proxy_pass http://$sticky_backend;

        proxy_next_upstream error timeout invalid_header http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
        proxy_connect_timeout 2s;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        # 웹소켓 연결 유지
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        # 웹소켓 성공 시에도 쿠키 갱신
        add_header Set-Cookie "SRV_ID=$inferred_name; Path=/; HttpOnly" always;

        proxy_intercept_errors off;
        proxy_cache_bypass $http_upgrade;
    }
}